# lingua_1 仓库根 — Recover / 节点联调环境变量示例（复制为 .env 后按本机修改）

# 仓库根（Electron 节点、词库 bundle、KenLM 默认路径解析）
PROJECT_ROOT=

# Sentence KenLM（Recover SENTENCE_REPAIR，非 CTC asr_kenlm_meta）
# 推荐：kenLM/model/zh_char_3gram.trie.bin（bash kenLM/scripts/setup_and_train.sh）
# 或：models/kenlm/zh_char_3gram/zh_char_3gram.trie.bin
CHAR_LM_PATH=

# KenLM query：kenLM/kenlm/build/bin/query（WSL）或 Windows query.exe
KENLM_QUERY_PATH=

# 词库 bundle（空则使用 PROJECT_ROOT/node_runtime/lexicon/current）
LEXICON_BUNDLE_PATH=
