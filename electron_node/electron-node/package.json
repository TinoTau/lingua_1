{
  "name": "lingua-electron-node",
  "version": "0.1.0",
  "description": "Lingua 分布式语音翻译系统 - Electron Node 客户端",
  "main": "dist/main/electron-node/main/src/index.js",
  "scripts": {
    "dev": "node scripts/setup-cleanup-handlers.js && concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -w --project tsconfig.main.json",
    "dev:renderer": "vite",
    "cleanup:esbuild": "node scripts/cleanup-esbuild.js",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc --project tsconfig.main.json && node scripts/fix-service-type-export.js",
    "build:renderer": "vite build",
    "start": "electron .",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux",
    "test": "jest",
    "test:stage3.1": "jest --config tests/stage3.1/jest.config.js",
    "test:stage3.1:watch": "jest --config tests/stage3.1/jest.config.js --watch",
    "test:pipeline": "jest --config tests/pipeline/jest.config.js",
    "test:fw-detector": "jest --testPathPattern=\"fw-detector|pipeline-mode-fw|freeze-contract|kenlm-span-gate|local-span-recall|domain-filter|apply-span-replacements\"",
    "test:aggregator": "npm run build:main && node tests/run-aggregator-test.js",
    "test:aggregator:vectors": "npm run build:main && node tests/run-aggregator-test-vectors.js",
    "test:aggregator:ts": "npx ts-node --project tsconfig.main.json tests/aggregator-test.ts",
    "clear-cache": "powershell -ExecutionPolicy Bypass -File scripts/clear-cache.ps1",
    "build:lexicon-bundle": "node scripts/lexicon/build-for-electron.mjs",
    "lexicon:validate": "node scripts/lexicon/validate-lexicon-seed.mjs",
    "lexicon:build:v2-shadow": "node scripts/lexicon/build-v2-shadow-for-electron.mjs",
    "lexicon:build:v2-shadow:raw": "node scripts/lexicon/build-lexicon-v2-shadow.mjs",
    "lexicon:test:v2-shadow-input": "node scripts/lexicon/lib/resolve-v2-shadow-input.test.mjs",
    "lexicon:build": "node scripts/lexicon/build-for-electron.mjs",
    "lexicon:build:raw": "node scripts/lexicon/build-lexicon-bundle.mjs",
    "lexicon:rebuild-sqlite": "node scripts/lexicon/rebuild-sqlite-for-electron.mjs",
    "lexicon:patch-merge": "node scripts/lexicon/patch-merge.mjs",
    "lexicon:report": "node scripts/lexicon/report.mjs",
    "lexicon:1k-sanitize": "node scripts/lexicon/sanitize-1k-pilot-seed.mjs",
    "lexicon:1k-pilot": "node scripts/lexicon/run-1k-pilot-acceptance.mjs",
    "lexicon:10k-prepare": "node scripts/lexicon/prepare-10k-seed.mjs",
    "lexicon:10k-pilot": "node scripts/lexicon/run-10k-pilot-acceptance.mjs",
    "lexicon:calibrate": "node scripts/lexicon/calibrate-prior.mjs",
    "lexicon:alias-report": "node scripts/lexicon/alias-collision-report.mjs",
    "lexicon:canonical-benchmark": "node scripts/lexicon/run-canonical-benchmark.mjs",
    "lexicon:phase5-assets": "node scripts/lexicon/generate-phase5-evaluation-assets.mjs",
    "lexicon:5k-prepare": "node scripts/lexicon/prepare-5k-seed.mjs",
    "lexicon:phase5-benchmark": "node scripts/lexicon/run-phase5-benchmark-suite.mjs",
    "lexicon:phase5-acceptance": "node scripts/lexicon/run-phase5-acceptance.mjs",
    "lexicon:source-manager": "node scripts/lexicon/canonical-source-manager.mjs",
    "lexicon:alias-benchmark": "node scripts/lexicon/run-alias-benchmark.mjs",
    "lexicon:v3-gate": "node scripts/lexicon/run-v3-runtime-gate.mjs",
    "lexicon:prepare:v3-runtime": "node scripts/lexicon/prepare-lexicon-v3-runtime-from-shadow.mjs",
    "lexicon:migrate:v3-runtime": "node scripts/lexicon/migrate-lexicon-v3-runtime-single-manifest.mjs",
    "lexicon:gate:v3-runtime": "node scripts/lexicon/run-gate-v3-runtime.mjs",
    "lexicon:patch:apply": "node scripts/lexicon/apply-lexicon-patch-v3.mjs",
    "test:lexicon-patch-e2e": "npm run build:main && node scripts/lexicon/run-patch-e2e.mjs",
    "lexicon:import-v3-assets": "node scripts/lexicon/import-v3-canonical-asset.mjs --review-status approved",
    "lexicon:import-v3-5k-assets": "node scripts/lexicon/import-v3-canonical-asset.mjs --ladder 5k --review-status approved",
    "test:lexicon": "jest --config jest.lexicon.config.js",
    "test:sentence-kenlm": "jest --testPathPattern=\"sentence-kenlm|lm-scorer|char-tokenize\"",
    "test:contract": "npm run build:main && jest --testPathPattern=\"legacy-asr-repair-contract|result-builder\"",
    "test:recover": "jest --testPathPattern=\"legacy/asr-repair|legacy-asr-repair-contract\"",
    "test:asr-repair": "npm run test:recover",
    "pinyin-ime-v2:export:all": "node scripts/pinyin-ime-v2/export-ime-dict.mjs --layer all",
    "pinyin-ime-v2:export:base": "node scripts/pinyin-ime-v2/export-ime-dict.mjs --layer base",
    "pinyin-ime-v2:export:domain": "node scripts/pinyin-ime-v2/export-ime-dict.mjs --layer domain",
    "pinyin-ime-v2:export:target": "node scripts/pinyin-ime-v2/export-ime-dict.mjs --layer target"
  },
  "keywords": [
    "electron",
    "speech-translation",
    "distributed-computing"
  ],
  "author": "Lingua Team",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@minceraftmc/opus-encoder": "^0.0.7-rc.1",
    "adm-zip": "^0.5.10",
    "axios": "^1.0.0",
    "better-sqlite3": "^11.7.0",
    "fft.js": "^4.0.4",
    "lru-cache": "10.4.3",
    "module-alias": "^2.2.3",
    "opencc-js": "^1.3.1",
    "opus-decoder": "^0.7.11",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "pinyin-pro": "^3.26.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "systeminformation": "^5.0.0",
    "ws": "^8.0.0"
  }
}
